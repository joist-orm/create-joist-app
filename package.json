{
  "name": "create-joist-app-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A run build",
    "test": "yarn workspaces foreach -A run test",
    "db": "docker compose up -d db && yarn migrate && yarn codegen",
    "migrate": "env-cmd node --import tsx node_modules/.bin/joist-pg-migrate",
    "codegen": "env-cmd yarn workspace basic-template run codegen && yarn workspace graphql-template run codegen",
    "format": "prettier --write '**/*.{ts,js}' --ignore-path .gitignore"
  },
  "devDependencies": {
    "env-cmd": "^11.0.0",
    "joist-migration-utils": "^2.0.3",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsx": "^4.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
